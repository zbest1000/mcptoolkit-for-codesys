# Normalize all text files to LF in the repository (consistent across OSes).
* text=auto eol=lf

# Windows-only scripts keep CRLF on checkout.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary assets — never normalize line endings.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
